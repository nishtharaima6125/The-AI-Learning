{
  "root": "dist/",
  "clean_urls": true,
  "routes": {
    "/assets/*": "/assets/:splat",
    "/favicon.ico": "/favicon.ico",
    "/prompt": "/index.html",
    "/login": "/index.html",
    "/admin": "/index.html",
    "/blogs": "/index.html",
    "/*.js": "/:splat",
    "/*.css": "/:splat",
    "/*.png": "/:splat",
    "/*.jpg": "/:splat",
    "/*.jpeg": "/:splat",
    "/*.gif": "/:splat",
    "/*.svg": "/:splat",
    "/*.ico": "/:splat",
    "/*.woff": "/:splat",
    "/*.woff2": "/:splat",
    "/*.ttf": "/:splat",
    "/*.eot": "/:splat",
    "/**": "/index.html"
  }
}
