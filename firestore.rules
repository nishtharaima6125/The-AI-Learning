rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact form - anyone can create, no auth required
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if true;  // Admin access (add auth later)
    }
    
    // Prompts - public read, admin write
    match /prompts/{promptId} {
      allow read: if true;
      allow create, update, delete: if true;  // Add auth for admin later
    }
    
    // Blogs - public read, admin write
    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if true;  // Add auth for admin later
    }
  }
}
